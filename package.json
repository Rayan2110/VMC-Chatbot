{
  "name": "vmc-chatbot",
  "version": "0.1.0",
  "private": true,
  "description": "Chatbot conditionnel pour interventions VMC - Marques Confort",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "db:generate": "npm run generate -w @vmc/db",
    "db:push": "npm run push -w @vmc/db",
    "db:seed": "npm run seed -w @vmc/db",
    "db:studio": "npm run studio -w @vmc/db",
    "api:dev": "npm run dev -w @vmc/api",
    "web:dev": "npm run dev -w @vmc/web",
    "dev": "npm-run-all --parallel api:dev web:dev"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=18"
  }
}
